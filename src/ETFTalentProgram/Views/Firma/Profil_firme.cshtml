@model ETFTalentProgram.Models.FirmaProfil

@{
    ViewData["Title"] = "Profil firme";
    var naziv = ViewData["Naziv"] as string ?? string.Empty;
    var opisFirme = ViewData["OpisFirme"] as string ?? string.Empty;
    var industrijskiSektor = ViewData["IndustrijskiSektor"] as string ?? string.Empty;
    var velicinaFirme = ViewData["VelicinaFirme"] as ETFTalentProgram.Models.VelicinaFirme?
        ?? ETFTalentProgram.Models.VelicinaFirme.MALA;
    var godinaOsnivanja = ViewData["GodinaOsnivanja"] as int? ?? DateTime.Today.Year;
}

@await Html.PartialAsync("_FirmaNavigation")

<div class="mx-auto mb-5" style="max-width: 920px;">
    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <h2 class="h5 fw-bold mb-3">Profil firme</h2>
            <p class="text-muted">Azurirajte osnovne, kontakt i javne informacije o firmi.</p>

            <form id="firmaProfileForm" asp-action="Profil_firme" method="post" class="d-grid gap-4">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FirmaId" />

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Osnovne informacije</h3>
                        <div class="alert alert-warning">
                            Ako sacuvate izmjene, status verifikacije profila firme bit ce vracen na cekanje.
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="naziv">Naziv firme</label>
                                <input id="naziv" name="naziv" class="form-control" value="@naziv" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="industrijskiSektor">Industrijski sektor</label>
                                <input id="industrijskiSektor" name="industrijskiSektor" class="form-control" value="@industrijskiSektor" placeholder="IT, finansije, edukacija..." />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="velicinaFirme">Velicina firme</label>
                                <select id="velicinaFirme" name="velicinaFirme" class="form-control" asp-items="Html.GetEnumSelectList<ETFTalentProgram.Models.VelicinaFirme>()"></select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="godinaOsnivanja">Godina osnivanja</label>
                                <input id="godinaOsnivanja" name="godinaOsnivanja" type="number" min="1800" max="2100" class="form-control" value="@godinaOsnivanja" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold" for="opisFirme">Kratak opis firme u sistemu</label>
                                <textarea id="opisFirme" name="opisFirme" class="form-control" rows="3">@opisFirme</textarea>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Javni opis profila</h3>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="KratakOpis" class="form-label fw-semibold">Kratak opis</label>
                                <input asp-for="KratakOpis" class="form-control" placeholder="Npr. vodeca IT kompanija..." />
                                <span asp-validation-for="KratakOpis" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="PunOpis" class="form-label fw-semibold">Puni opis</label>
                                <textarea asp-for="PunOpis" class="form-control" rows="5" placeholder="Detaljniji opis poslovanja, kulture i oblasti rada..."></textarea>
                                <span asp-validation-for="PunOpis" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Kontakt informacije</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Lokacija" class="form-label fw-semibold">Lokacija</label>
                                <input asp-for="Lokacija" class="form-control" placeholder="Sarajevo, Bosna i Hercegovina" />
                                <span asp-validation-for="Lokacija" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Website" class="form-label fw-semibold">Website</label>
                                <input asp-for="Website" class="form-control" placeholder="https://www.kompanija.ba" />
                                <span asp-validation-for="Website" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="KontaktEmail" class="form-label fw-semibold">Kontakt email</label>
                                <input asp-for="KontaktEmail" class="form-control" type="email" placeholder="kontakt@kompanija.ba" />
                                <span asp-validation-for="KontaktEmail" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Dodatne informacije</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Logotip" class="form-label fw-semibold">Logotip URL</label>
                                <input asp-for="Logotip" class="form-control" placeholder="https://..." />
                                <span asp-validation-for="Logotip" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TehnologijeStack" class="form-label fw-semibold">Tehnologije</label>
                                <input asp-for="TehnologijeStack" class="form-control" placeholder="React, Node.js, PostgreSQL" />
                                <span asp-validation-for="TehnologijeStack" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Otkazi</a>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#confirmFirmaProfileModal">Sacuvaj izmjene</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmFirmaProfileModal" tabindex="-1" aria-labelledby="confirmFirmaProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="confirmFirmaProfileModalLabel">Potvrda izmjena profila</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
            </div>
            <div class="modal-body">
                Spremanjem izmjena status verifikacije profila firme bit ce postavljen na cekanje dok referent ponovo ne pregleda profil.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Odbaci</button>
                <button type="submit" form="firmaProfileForm" class="btn btn-primary">Potvrdi izmjene</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('velicinaFirme').value = '@velicinaFirme';
    </script>
}

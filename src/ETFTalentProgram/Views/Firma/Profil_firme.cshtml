@model ETFTalentProgram.Models.FirmaProfil

@{
    ViewData["Title"] = "Profil firme";
}

@await Html.PartialAsync("_FirmaNavigation")

<div class="mx-auto mb-5" style="max-width: 920px;">
    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <h2 class="h5 fw-bold mb-3">Osnovne informacije</h2>
            <p class="text-muted">Ažurirajte informacije o vašoj firmi</p>

            <form asp-action="Profil_firme" method="post" class="d-grid gap-4">
                <input type="hidden" asp-for="Id" />

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Opis firme</h3>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="KratakOpis" class="form-label fw-semibold">Kratak opis</label>
                                <input asp-for="KratakOpis" class="form-control" placeholder="Npr. Vodečica IT kompanija..." />
                                <span asp-validation-for="KratakOpis" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="PunOpis" class="form-label fw-semibold">Puni opis</label>
                                <textarea asp-for="PunOpis" class="form-control" rows="5" placeholder="Detaljniji opis vašeg poslovanja..."></textarea>
                                <span asp-validation-for="PunOpis" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Kontakt informacije</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Lokacija" class="form-label fw-semibold">Lokacija</label>
                                <input asp-for="Lokacija" class="form-control" placeholder="Sarajevo, Bosna i Hercegovina" />
                                <span asp-validation-for="Lokacija" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Website" class="form-label fw-semibold">Website</label>
                                <input asp-for="Website" class="form-control" placeholder="https://www.kompanija.ba" />
                                <span asp-validation-for="Website" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="KontaktEmail" class="form-label fw-semibold">Kontakt email</label>
                                <input asp-for="KontaktEmail" class="form-control" type="email" placeholder="kontakt@kompanija.ba" />
                                <span asp-validation-for="KontaktEmail" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Dodatne informacije</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Logotip" class="form-label fw-semibold">Logotip URL</label>
                                <input asp-for="Logotip" class="form-control" placeholder="https://..." />
                                <span asp-validation-for="Logotip" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TehnologijeStack" class="form-label fw-semibold">Tehnologije</label>
                                <input asp-for="TehnologijeStack" class="form-control" placeholder="React, Node.js, PostgreSQL" />
                                <span asp-validation-for="TehnologijeStack" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DatumAzuriranja" class="form-label fw-semibold">Datum ažuriranja</label>
                                <input asp-for="DatumAzuriranja" type="date" class="form-control" />
                                <span asp-validation-for="DatumAzuriranja" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FirmaId" class="form-label fw-semibold">Firma</label>
                                <select asp-for="FirmaId" class="form-control" asp-items="ViewBag.FirmaId"></select>
                                <span asp-validation-for="FirmaId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Otkaži</a>
                    <button type="submit" class="btn btn-primary">Sačuvaj izmjene</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

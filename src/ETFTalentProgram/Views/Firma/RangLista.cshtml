@model IReadOnlyList<ETFTalentProgram.ViewModels.StudentRangViewModel>

@{
    ViewData["Title"] = "Rang studenata";
}

@await Html.PartialAsync("_FirmaNavigation")

<div class="mx-auto mb-5" style="max-width: 1040px;">
    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
        <div>
            <h2 class="h4 fw-bold mb-1">Rang studenata</h2>
            <p class="text-muted mb-0">Score se formira iz polozenih predmeta, ocjena, ECTS bodova i vlastitih projekata.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Student</th>
                    <th>Prosjek</th>
                    <th>Predmeti</th>
                    <th>ECTS</th>
                    <th>Projekti</th>
                    <th>Tehnologije</th>
                    <th class="text-end">Rang</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.Count; i++)
                {
                    var student = Model[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>
                            <div class="fw-semibold">@student.ImePrezime</div>
                            <div class="text-muted small">@student.Email</div>
                        </td>
                        <td>@student.ProsjekOcjena.ToString("0.00")</td>
                        <td>@student.BrojPolozenihPredmeta</td>
                        <td>@student.UkupnoEcts</td>
                        <td>@student.BrojProjekata</td>
                        <td class="text-muted small">@student.PreferiraneTehnologije</td>
                        <td class="text-end fw-semibold">@student.Rang.ToString("0.00")</td>
                        <td class="text-end">
                            <form asp-action="KontaktirajStudenta" asp-route-id="@student.StudentId" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-primary">Kontaktiraj</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model ETFTalentProgram.Models.Oglas

@{
    ViewData["Title"] = "Objavi oglas";
}

@await Html.PartialAsync("_FirmaNavigation")

<div class="mx-auto mb-5" style="max-width: 920px;">
    <div class="card">
        <div class="card-body">
            <h2 class="h5 fw-bold mb-3">Kreiraj novi oglas</h2>
            <p class="text-muted">Popunite sve potrebne informacije za objavljivanje oglasa</p>

            <form asp-action="Objavi_oglas" method="post" class="d-grid gap-4">
                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Osnovne informacije</h3>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Naslov" class="form-label fw-semibold">Naziv pozicije *</label>
                                <input asp-for="Naslov" class="form-control" placeholder="npr. Frontend Developer, Backend Praksa..." required />
                                <span asp-validation-for="Naslov" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Opis" class="form-label fw-semibold">Opis pozicije *</label>
                                <textarea asp-for="Opis" class="form-control" rows="5" placeholder="Opis pozicije, odgovornosti i kvalifikacija..." required></textarea>
                                <span asp-validation-for="Opis" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Tehnicki zahtjevi</h3>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Tehnologije" class="form-label fw-semibold">Trazene tehnologije *</label>
                                <input asp-for="Tehnologije" class="form-control" placeholder="React, Node.js, PostgreSQL..." required />
                                <span asp-validation-for="Tehnologije" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MinRang" class="form-label fw-semibold">Minimalni rang</label>
                                <input asp-for="MinRang" type="number" step="0.1" class="form-control" placeholder="npr. 6.5" />
                                <span asp-validation-for="MinRang" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MinProsjek" class="form-label fw-semibold">Minimalni prosjek</label>
                                <input asp-for="MinProsjek" type="number" step="0.1" class="form-control" placeholder="npr. 8.0" />
                                <span asp-validation-for="MinProsjek" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Uvjeti angazmana</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="TipOglasa" class="form-label fw-semibold">Tip oglasa *</label>
                                <select asp-for="TipOglasa" class="form-control" asp-items="Html.GetEnumSelectList<ETFTalentProgram.Models.TipOglasa>()" required></select>
                                <span asp-validation-for="TipOglasa" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TipAngazmana" class="form-label fw-semibold">Tip angazmana *</label>
                                <select asp-for="TipAngazmana" class="form-control" asp-items="Html.GetEnumSelectList<ETFTalentProgram.Models.TipAngazmana>()" required></select>
                                <span asp-validation-for="TipAngazmana" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Lokacija" class="form-label fw-semibold">Lokacija *</label>
                                <input asp-for="Lokacija" class="form-control" placeholder="Sarajevo, Remote..." required />
                                <span asp-validation-for="Lokacija" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Kompenzacija" class="form-label fw-semibold">Kompenzacija</label>
                                <input asp-for="Kompenzacija" class="form-control" placeholder="npr. 1000-1500 KM" />
                                <span asp-validation-for="Kompenzacija" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-body">
                        <h3 class="h6 fw-semibold mb-3">Datumi i status</h3>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="DatumObjave" class="form-label fw-semibold">Datum objave</label>
                                <input asp-for="DatumObjave" type="date" class="form-control" />
                                <span asp-validation-for="DatumObjave" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="RokPrijave" class="form-label fw-semibold">Rok prijave</label>
                                <input asp-for="RokPrijave" type="date" class="form-control" />
                                <span asp-validation-for="RokPrijave" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="StatusOglasa" class="form-label fw-semibold">Status oglasa</label>
                                <select asp-for="StatusOglasa" class="form-control" asp-items="Html.GetEnumSelectList<ETFTalentProgram.Models.StatusOglasa>()"></select>
                                <span asp-validation-for="StatusOglasa" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </section>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Otkazi</a>
                    <button type="submit" class="btn btn-primary">Objavi oglas</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

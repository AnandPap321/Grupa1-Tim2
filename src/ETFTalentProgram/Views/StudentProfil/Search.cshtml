@model IEnumerable<ETFTalentProgram.ViewModels.StudentProfilViewModel>

@{
    ViewData["Title"] = "Pretraži studente";
    var query = ViewData["Query"] as string;
    var minimalniRang = ViewData["MinimalniRang"];
    var tehnologija = ViewData["Tehnologija"] as string;
}

<div class="mx-auto mb-5" style="max-width: 1180px;">
    <div class="my-4">
        <p class="text-muted mb-1">ETF Talent Program</p>
        <h1 class="fw-bold mb-0">Pretraži studente</h1>
    </div>

    <section class="card">
        <div class="card-body">
            <h2 class="h5 fw-bold">Napredna pretraga</h2>
            <p class="text-muted">Pronađite talente koji odgovaraju vašim zahtjevima</p>
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Pretraga</label>
                    <input name="q" class="form-control" value="@query" placeholder="Ime ili vještina..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Minimalni rang</label>
                    <input name="minimalniRang" type="number" step="0.1" min="0" max="10" class="form-control" value="@minimalniRang" placeholder="npr. 8.0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Tehnologija</label>
                    <input name="tehnologija" class="form-control" value="@tehnologija" placeholder="React, Java..." />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">Pretraži</button>
                </div>
            </form>
        </div>
    </section>

    <p class="text-muted my-4">@Model.Count() studenata pronađeno</p>

    <div class="d-grid gap-3">
        @foreach (var profil in Model)
        {
            <article class="card">
                <div class="card-body d-flex flex-column flex-lg-row justify-content-between gap-4">
                    <div class="flex-grow-1">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h2 class="h5 fw-bold mb-0">@(string.IsNullOrWhiteSpace(profil.PunoIme) ? "Student" : profil.PunoIme)</h2>
                            <span class="badge text-bg-light border">@profil.GodinaStudija. godina</span>
                        </div>
                        <p class="text-muted mt-2">@(string.IsNullOrWhiteSpace(profil.Biografija) ? "Biografija nije unesena." : profil.Biografija)</p>
                        <div class="d-flex flex-wrap gap-4 my-3">
                            <span class="text-muted">Rang <strong class="d-block text-dark">@profil.Rang.ToString("0.0")/10</strong></span>
                            <span class="text-muted">Prosjek <strong class="d-block text-dark">@profil.ProsjekOcjena.ToString("0.##")</strong></span>
                            <span class="text-muted">Projekti <strong class="d-block text-dark">@profil.BrojProjekata</strong></span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var vjestina in profil.VjestineLista)
                            {
                                <span class="badge text-bg-light border">@vjestina</span>
                            }
                        </div>
                        @if (profil.LokacijeLista.Count > 0)
                        {
                            <p class="text-muted small mt-3 mb-0">Preferirane lokacije: @string.Join(", ", profil.LokacijeLista)</p>
                        }
                    </div>
                    <div class="d-grid gap-2 align-self-lg-start" style="min-width: 160px;">
                        <a asp-action="Details" asp-route-id="@profil.Id" class="btn btn-outline-primary">Pregledaj profil</a>
                        <a asp-controller="Ponuda" asp-action="Create" asp-route-primalacId="@profil.StudentId" class="btn btn-primary">Pošalji ponudu</a>
                    </div>
                </div>
            </article>
        }
    </div>
</div>

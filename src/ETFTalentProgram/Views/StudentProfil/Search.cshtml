@model IEnumerable<ETFTalentProgram.ViewModels.StudentProfilViewModel>

@{
    ViewData["Title"] = "Pretrazi studente";
    var query = ViewData["Query"] as string;
    var minimalniRang = ViewData["MinimalniRang"];
    var tehnologija = ViewData["Tehnologija"] as string;
    var predmet = ViewData["Predmet"] as string;
    var projekat = ViewData["Projekat"] as string;
    var samoZavrsnaGodina = ViewData["SamoZavrsnaGodina"] as bool? ?? true;
}

@await Html.PartialAsync("_FirmaNavigation")

<div class="mx-auto mb-5" style="max-width: 1180px;">
    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <section class="card">
        <div class="card-body">
            <h2 class="h5 fw-bold">Pretraga kandidata</h2>
            <p class="text-muted">Pronadjite studente zavrsne godine ili svrsenike prvog ciklusa prema predmetima, tehnologijama i projektima.</p>

            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Pretraga</label>
                    <input name="q" class="form-control" value="@query" placeholder="Ime, vjestina ili projekat..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Minimalni rang</label>
                    <input name="minimalniRang" type="number" step="0.1" min="0" max="1000" class="form-control" value="@minimalniRang" placeholder="npr. 80" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Tehnologija</label>
                    <input name="tehnologija" class="form-control" value="@tehnologija" placeholder="React, Java, .NET..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Polozeni predmet</label>
                    <input name="predmet" class="form-control" value="@predmet" placeholder="OOAD, RPR..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Projekat</label>
                    <input name="projekat" class="form-control" value="@projekat" placeholder="Web, API..." />
                </div>
                <div class="col-md-5">
                    <div class="form-check">
                        <input name="samoZavrsnaGodina" type="checkbox" class="form-check-input" value="true" checked="@samoZavrsnaGodina" />
                        <input name="samoZavrsnaGodina" type="hidden" value="false" />
                        <label class="form-check-label">Samo studenti zavrsne godine ili svrsenici prvog ciklusa</label>
                    </div>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">Pretrazi</button>
                </div>
                <div class="col-md-2 d-grid">
                    <a asp-action="Search" class="btn btn-outline-secondary">Ocisti</a>
                </div>
            </form>
        </div>
    </section>

    <p class="text-muted my-4">@Model.Count() studenata pronadjeno</p>

    <div class="d-grid gap-3">
        @foreach (var profil in Model)
        {
            <article class="card">
                <div class="card-body d-flex flex-column flex-lg-row justify-content-between gap-4">
                    <div class="flex-grow-1">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <h2 class="h5 fw-bold mb-0">@(string.IsNullOrWhiteSpace(profil.PunoIme) ? "Student" : profil.PunoIme)</h2>
                            <span class="badge text-bg-light border">@profil.GodinaStudija. godina</span>
                            <span class="badge text-bg-light border">@profil.StatusVerifikacije</span>
                        </div>
                        <p class="text-muted mt-2">@(string.IsNullOrWhiteSpace(profil.Biografija) ? "Biografija nije unesena." : profil.Biografija)</p>
                        <div class="d-flex flex-wrap gap-4 my-3">
                            <span class="text-muted">Rang <strong class="d-block text-dark">@profil.Rang.ToString("0.0")</strong></span>
                            <span class="text-muted">Prosjek <strong class="d-block text-dark">@profil.ProsjekOcjena.ToString("0.##")</strong></span>
                            <span class="text-muted">ECTS <strong class="d-block text-dark">@profil.EctsBodovi</strong></span>
                            <span class="text-muted">Projekti <strong class="d-block text-dark">@profil.BrojProjekata</strong></span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var vjestina in profil.VjestineLista)
                            {
                                <span class="badge text-bg-light border">@vjestina</span>
                            }
                        </div>
                        @if (profil.ProjektiLista.Count > 0)
                        {
                            <div class="mt-3">
                                <div class="text-muted small fw-semibold mb-1">Projekti</div>
                                <ul class="mb-0 ps-3">
                                    @foreach (var studentProjekat in profil.ProjektiLista.Take(3))
                                    {
                                        <li>@studentProjekat.Naziv</li>
                                    }
                                </ul>
                            </div>
                        }
                        @if (profil.LokacijeLista.Count > 0)
                        {
                            <p class="text-muted small mt-3 mb-0">Preferirane lokacije: @string.Join(", ", profil.LokacijeLista)</p>
                        }
                    </div>
                    <div class="d-grid gap-2 align-self-lg-start" style="min-width: 170px;">
                        <a asp-action="Details" asp-route-id="@profil.Id" class="btn btn-outline-primary">Pregledaj profil</a>
                        <form asp-controller="Firma" asp-action="KontaktirajStudenta" asp-route-id="@profil.StudentId" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary w-100">Kontaktiraj</button>
                        </form>
                    </div>
                </div>
            </article>
        }
    </div>
</div>

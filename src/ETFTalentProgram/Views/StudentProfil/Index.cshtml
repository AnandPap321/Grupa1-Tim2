@model ETFTalentProgram.ViewModels.StudentProfilViewModel

@{
    ViewData["Title"] = "Moj profil";
}

@await Html.PartialAsync("_StudentNavigation")

<div class="mx-auto mb-5" style="max-width: 1040px;">
    <section class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-4">
                <div class="d-flex gap-3 align-items-start">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-bold fs-4 flex-shrink-0" style="width: 72px; height: 72px;">@Model.Inicijali</span>
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <h2 class="h3 fw-bold mb-0">@(string.IsNullOrWhiteSpace(Model.PunoIme) ? "Moj profil" : Model.PunoIme)</h2>
                            <span class="badge text-bg-light border">@Model.StatusVerifikacije</span>
                        </div>
                        <p class="text-muted mb-2">Student - @(Model.GodinaStudija == 0 ? "godina nije unesena" : $"{Model.GodinaStudija}. godina")</p>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge rounded-pill text-bg-primary">Rang @Model.Rang.ToString("0.0")/10</span>
                            <span class="badge rounded-pill text-bg-light border">@Model.EctsBodovi ECTS</span>
                            <span class="badge rounded-pill text-bg-light border">@Model.BrojVjestina vjestina</span>
                            <span class="badge rounded-pill text-bg-light border">@Model.BrojProjekata projekta</span>
                        </div>
                    </div>
                </div>
                <div class="text-lg-end">
                    <div class="text-muted small">Dostupan od</div>
                    <div class="fw-semibold">@Model.DostupanOd.ToString("dd.MM.yyyy")</div>
                    <div class="text-muted small mt-2">Zadnje azuriranje</div>
                    <div class="fw-semibold">@Model.DatumAzuriranja.ToString("dd.MM.yyyy")</div>
                </div>
            </div>
        </div>
    </section>

    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form id="studentProfileForm" asp-action="Update" method="post" class="d-grid gap-4">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="StudentId" />

        <section class="card">
            <div class="card-body">
                <h2 class="h5 fw-bold">Osnovne informacije</h2>
                <p class="text-muted">Vasi osnovni podaci i kontakt informacije.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Ime" class="form-label fw-semibold">Ime</label>
                        <input asp-for="Ime" class="form-control" />
                        <span asp-validation-for="Ime" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Prezime" class="form-label fw-semibold">Prezime</label>
                        <input asp-for="Prezime" class="form-control" />
                        <span asp-validation-for="Prezime" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BrojIndeksa" class="form-label fw-semibold">Broj indeksa</label>
                        <input asp-for="BrojIndeksa" class="form-control" />
                        <span asp-validation-for="BrojIndeksa" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="GodinaStudija" class="form-label fw-semibold">Godina studija</label>
                        <input asp-for="GodinaStudija" type="number" min="0" max="10" class="form-control" />
                        <span asp-validation-for="GodinaStudija" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="GodinaUpisa" class="form-label fw-semibold">Godina upisa</label>
                        <input asp-for="GodinaUpisa" type="number" min="1990" max="2100" class="form-control" />
                        <span asp-validation-for="GodinaUpisa" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input class="form-control" value="@Model.Email" disabled />
                    </div>
                </div>
                <div class="alert alert-warning mt-3 mb-0">
                    Ako sacuvate izmjene, status verifikacije profila bit ce vracen na cekanje.
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-body">
                <h2 class="h5 fw-bold">Akademski podaci</h2>
                <p class="text-muted">Vas akademski uspjeh i rang.</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="ProsjekOcjena" class="form-label fw-semibold">Prosjecna ocjena</label>
                        <input asp-for="ProsjekOcjena" type="number" min="0" max="10" step="0.01" class="form-control" />
                        <span asp-validation-for="ProsjekOcjena" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">ECTS bodova</label>
                        <input class="form-control" value="@Model.EctsBodovi" disabled />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Rang</label>
                        <input class="form-control fw-bold text-primary" value="@Model.Rang.ToString("0.0")/10" disabled />
                    </div>
                </div>
                <div class="alert alert-primary mt-3 mb-0">
                    Rang se automatski izracunava na osnovu ocjena, projekata i vjestina. Azurira se svaki put kada izmijenite profil.
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-body">
                <h2 class="h5 fw-bold">Biografija</h2>
                <p class="text-muted">Kratko predstavite sebe poslodavcima.</p>
                <textarea asp-for="Biografija" class="form-control" rows="4" placeholder="Npr. Student trece godine softverskog inzenjerstva sa interesom za web development."></textarea>
                <span asp-validation-for="Biografija" class="text-danger"></span>
            </div>
        </section>

        <section class="card">
            <div class="card-body">
                <h2 class="h5 fw-bold">Vjestine i tehnologije</h2>
                <p class="text-muted">Programski jezici, framework-ovi i alati koje poznajete.</p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var vjestina in Model.VjestineLista)
                    {
                        <span class="badge text-bg-light border">@vjestina</span>
                    }
                </div>
                <input asp-for="Vjestine" class="form-control" placeholder="React, TypeScript, Node.js, PostgreSQL" />
                <span asp-validation-for="Vjestine" class="text-danger"></span>
            </div>
        </section>

        <section class="card">
            <div class="card-body">
                <h2 class="h5 fw-bold">Projekti</h2>
                <p class="text-muted">Vasi licni i akademski projekti.</p>
                <div class="d-grid gap-3">
                    @foreach (var projekat in Model.ProjektiLista)
                    {
                        <article class="border rounded p-3">
                            <strong class="d-block">@projekat.Naziv</strong>
                            @if (!string.IsNullOrWhiteSpace(projekat.Opis))
                            {
                                <span class="d-block text-muted mt-1">@projekat.Opis</span>
                            }
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                @foreach (var tehnologija in projekat.Tehnologije)
                                {
                                    <span class="badge text-bg-light border">@tehnologija</span>
                                }
                            </div>
                        </article>
                    }
                </div>
                <label asp-for="Projekti" class="form-label fw-semibold mt-3">Projekti</label>
                <textarea asp-for="Projekti" class="form-control" rows="5" placeholder="E-commerce platforma | Full-stack web aplikacija | React, Node.js, MongoDB"></textarea>
                <div class="form-text">Unesite svaki projekat u novi red u formatu: Naziv | Opis | Tehnologije.</div>
                <span asp-validation-for="Projekti" class="text-danger"></span>
            </div>
        </section>

        <section class="card">
            <div class="card-body">
                <h2 class="h5 fw-bold">Preferencije</h2>
                <p class="text-muted">Zeljena lokacija i dostupnost.</p>
                <label asp-for="PreferiraneLokacije" class="form-label fw-semibold">Preferirane lokacije</label>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var lokacija in Model.LokacijeLista)
                    {
                        <span class="badge text-bg-light border">@lokacija</span>
                    }
                </div>
                <input asp-for="PreferiraneLokacije" class="form-control" placeholder="Sarajevo, Remote" />
                <span asp-validation-for="PreferiraneLokacije" class="text-danger"></span>

                <label asp-for="DostupanOd" class="form-label fw-semibold mt-3">Dostupan od</label>
                <input asp-for="DostupanOd" type="date" class="form-control" />
                <span asp-validation-for="DostupanOd" class="text-danger"></span>
            </div>
        </section>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="d-flex justify-content-end">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#confirmStudentProfileModal">Sacuvaj izmjene</button>
        </div>
    </form>
</div>

<div class="modal fade" id="confirmStudentProfileModal" tabindex="-1" aria-labelledby="confirmStudentProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="confirmStudentProfileModalLabel">Potvrda izmjena profila</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zatvori"></button>
            </div>
            <div class="modal-body">
                Spremanjem izmjena status verifikacije vaseg studentskog profila bit ce postavljen na cekanje dok referent ponovo ne pregleda profil.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Odbaci</button>
                <button type="submit" form="studentProfileForm" class="btn btn-primary">Potvrdi izmjene</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

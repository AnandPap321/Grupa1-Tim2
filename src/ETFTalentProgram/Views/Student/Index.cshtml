@model ETFTalentProgram.ViewModels.StudentPocetnaViewModel

@{
    ViewData["Title"] = "Pocetna";
}

<div class="d-flex flex-column gap-4">
    <section class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <p class="text-muted mb-1">ETF Talent Program</p>
            <h1 class="mb-1">Zdravo, @(string.IsNullOrWhiteSpace(Model.PunoIme) ? "student" : Model.PunoIme)</h1>
            <span class="badge text-bg-light border">Status profila: @Model.StatusVerifikacije</span>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" asp-controller="StudentProfil" asp-action="Index">Moj profil</a>
            <a class="btn btn-outline-secondary" asp-controller="Oglas" asp-action="Index">Oglasi</a>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <span class="text-muted">Rang</span>
                    <strong class="d-block fs-3 text-primary mt-2">@Model.Rang.ToString("0.0")</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <span class="text-muted">Prijave</span>
                    <strong class="d-block fs-3 text-primary mt-2">@Model.BrojPrijava</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <span class="text-muted">Ponude</span>
                    <strong class="d-block fs-3 text-primary mt-2">@Model.BrojPonuda</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <span class="text-muted">Projekti</span>
                    <strong class="d-block fs-3 text-primary mt-2">@Model.BrojProjekata</strong>
                </div>
            </div>
        </div>
    </div>

    @if (Model.StatusVerifikacije != ETFTalentProgram.Models.StatusVerifikacije.VERIFICIRAN)
    {
        <div class="alert alert-warning mb-0">
            Profil jos nije verificiran. Ažurirajte podatke na profilu, a referent ce izvrsiti provjeru.
        </div>
    }

    <section class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 mb-0">Najnoviji oglasi</h2>
                <a asp-controller="Oglas" asp-action="Index">Svi oglasi</a>
            </div>

            @if (Model.NajnovijiOglasi.Count == 0)
            {
                <p class="text-muted mb-0">Trenutno nema aktivnih oglasa.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var oglas in Model.NajnovijiOglasi)
                    {
                        <a class="list-group-item list-group-item-action px-0" asp-controller="Oglas" asp-action="Details" asp-route-id="@oglas.Id">
                            <div class="d-flex w-100 justify-content-between gap-3">
                                <div>
                                    <strong>@oglas.Naslov</strong>
                                    <div class="text-muted">@oglas.Firma?.Naziv - @oglas.Lokacija</div>
                                </div>
                                <small class="text-muted">@oglas.RokPrijave.ToString("dd.MM.yyyy")</small>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
</div>

@model IEnumerable<ETFTalentProgram.Models.RangParametri>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TezinaProsjecneOcjene)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TezinaECTS)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TezinaBrojVjestina)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TezinaBrojProjekata)

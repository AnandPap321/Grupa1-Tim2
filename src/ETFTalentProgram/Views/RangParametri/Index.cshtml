            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TezinaProsjecneOcjene)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TezinaECTS)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TezinaBrojVjestina)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TezinaBrojProjekata)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Verzija)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumPrimjene)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |

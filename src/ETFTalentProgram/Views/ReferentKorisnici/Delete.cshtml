@model ETFTalentProgram.ViewModels.UserManagementIndexViewModel

@{
    ViewData["Title"] = "Brisanje korisnika";
}

<h1>Brisanje korisnika</h1>

<div class="alert alert-warning">
    Da li ste sigurni da zelite obrisati korisnika <strong>@Model.Email</strong>?
</div>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Uloge</dt>
    <dd class="col-sm-9">@Model.Roles</dd>

    <dt class="col-sm-3">Datum registracije</dt>
    <dd class="col-sm-9">@Model.DatumRegistracije.ToString("dd.MM.yyyy HH:mm")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Obrisi</button>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</form>

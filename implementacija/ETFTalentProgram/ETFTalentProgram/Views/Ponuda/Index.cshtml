@model IEnumerable<ETFTalentProgram.Models.Ponuda>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TekstPoruke)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumSlanja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipPonude)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumOdgovora)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Posiljalac)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Primalac)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TekstPoruke)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumSlanja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipPonude)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumOdgovora)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Posiljalac.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Primalac.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

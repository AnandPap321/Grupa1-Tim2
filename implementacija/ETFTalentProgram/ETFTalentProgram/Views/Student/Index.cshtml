                @Html.DisplayNameFor(model => model.DatumRegistracije)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumZadnjePrijave)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Ime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prezime)

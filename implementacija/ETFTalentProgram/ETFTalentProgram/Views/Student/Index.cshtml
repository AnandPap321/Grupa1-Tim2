@model IEnumerable<ETFTalentProgram.Models.Student>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Ime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prezime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BrIndeksa)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GodinaStudija)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GodinaUpisa)

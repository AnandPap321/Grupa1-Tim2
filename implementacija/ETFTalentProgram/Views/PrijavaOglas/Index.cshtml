@model IEnumerable<ETFTalentProgram.Models.PrijavaOglas>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DatumPrijave)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PropratniTekst)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StatusPrijave)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumOdgovora)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Student)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Oglas)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.DatumPrijave)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PropratniTekst)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StatusPrijave)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumOdgovora)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Student.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Oglas.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

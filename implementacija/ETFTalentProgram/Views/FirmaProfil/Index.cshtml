@model IEnumerable<ETFTalentProgram.Models.FirmaProfil>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.KratakOpis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PunOpis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Lokacija)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Website)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.KontaktEmail)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Logotip)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TehnologijeStack)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DatumAzuriranja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Firma)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.KratakOpis)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PunOpis)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Lokacija)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Website)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.KontaktEmail)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Logotip)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TehnologijeStack)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DatumAzuriranja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Firma.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
